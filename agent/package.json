{
  "name": "livekit-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@livekit/agents": "^1.2.0",
    "@livekit/agents-plugin-google": "^1.2.0",
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@effect/vitest": "^0.27.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "dev": "tsx --env-file=.env src/agent.ts dev",
    "build": "tsc",
    "start": "node dist/agent.js start",
    "download-files": "tsc && node dist/agent.js download-files",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write"
  }
}
