# Server public IP (required for WebRTC connectivity)
NODE_IP=

# Domain pointing to this server (e.g. livekit.sonavera.com)
LIVEKIT_DOMAIN=

# LiveKit credentials — must match keys in livekit.yaml
# Generate: openssl rand -hex 24
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Monitoring
GRAFANA_DOMAIN=
GF_SECURITY_ADMIN_PASSWORD=

# Google Gemini
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

# Optional agent overrides
# GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# GEMINI_VOICE=Kore
# GEMINI_TEMPERATURE=0.8
# GEMINI_LANGUAGE=he-IL
# GEMINI_TRANSCRIPTION_LANGUAGE_CODES=he-IL
